MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ecopark_db
MYSQL_USER=ecopark_user
MYSQL_PASSWORD=change-me

ONEC_API_URL=http://onec-host/ecopark/hs/ecopark-sync/snapshot
ONEC_API_USER=onec-user
ONEC_API_PASSWORD=change-me

REQUEST_TIMEOUT_SECONDS=120

# Python scheduler settings.
SCHEDULE_MODE=daily
SCHEDULE_TIMEZONE=Asia/Novosibirsk
SYNC_DAILY_AT=13:00
GOOGLE_SHEETS_DAILY_AT=13:10
SYNC_EXPORT_AFTER_SYNC=false

# Flask admin interface.
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=false
WEB_SYNC_ENABLED=true

# Google Sheets export.
GOOGLE_SHEETS_EXPORT_ENABLED=true
GOOGLE_SHEETS_SPREADSHEET_ID=spreadsheet-id
GOOGLE_SHEETS_WORKSHEET=Участки
GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google-service-account.json
